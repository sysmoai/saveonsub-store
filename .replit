run = "python3 -m http.server 8080"
language = "html"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "-m", "http.server", "8080"]
build = ["bash", "build_all.sh"]

[env]
PYTHONUNBUFFERED = "1"

[git]
ignoreBranch = false
